# ===== WhatsApp Cloud API (Meta) =====
# Token permanente do System User (Meta Business)
WHATSAPP_TOKEN=
# ID do número de telefone (painel do app Meta > WhatsApp > API Setup)
PHONE_NUMBER_ID=
# Palavra secreta que você escolhe; a mesma vai no painel da Meta ao configurar o webhook
VERIFY_TOKEN=escolha-uma-senha-qualquer

# ===== OpenAI (transcrição + leitura de placa + estruturação) =====
OPENAI_API_KEY=
# opcional; padrão gpt-4o-mini
OPENAI_MODEL=

# ===== Google (planilha + arquivos) =====
# Conteúdo INTEIRO do JSON da service account, numa linha só
GOOGLE_CREDENTIALS_JSON=
# ID da planilha (o trecho do link entre /d/ e /edit)
SHEET_ID=
# ID da pasta do Drive (o trecho final do link da pasta)
DRIVE_FOLDER_ID=

# ===== Oficina =====
NOME_OFICINA=OFICINA DO ZE
INFO_OFICINA=Rua Exemplo, 123 - (11) 99999-0000
TEXTO_GARANTIA=Garantia do servico: 90 dias
# Números de WhatsApp que podem usar o bot, com DDI, separados por vírgula
ALLOWED_NUMBERS=5511999990000
